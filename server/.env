# 数据库（SQLite，本地零配置运行）
DATABASE_URL="file:./dev.db"

# JWT 密钥
JWT_SECRET="trip-aa-secret-key-change-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="30d"

# 服务端口
PORT=3000

# 微信小程序配置（本地开发使用 mock 登录）
WX_APPID="mock_appid"
WX_SECRET="mock_secret"
WX_MOCK_OPENID="mock_openid_001"

# 文件上传目录
UPLOAD_DIR="./uploads"
